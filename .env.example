# ============================================================
# Open Clinic AI — Configuração de Ambiente
#
# 1. Copie este arquivo: cp .env.example .env
# 2. Preencha os valores abaixo
# 3. NUNCA versione o arquivo .env (já está no .gitignore)
# ============================================================


# ── DOMÍNIO (obrigatório em produção) ────────────────────────
# Seu domínio apontando para o IP da VPS via registro DNS tipo A
DOMAIN=clinica.seudominio.com.br

# E-mail para o Let's Encrypt (recebe avisos de renovação)
ACME_EMAIL=seuemail@dominio.com


# ── BANCO DE DADOS ───────────────────────────────────────────
# Senha forte para o PostgreSQL (mín. 16 caracteres)
DB_PASSWORD=troque_por_senha_muito_forte


# ── SEGURANÇA ────────────────────────────────────────────────
# Chave secreta para JWT — gere com: openssl rand -hex 32
SECRET_KEY=


# ── TELEGRAM ─────────────────────────────────────────────────
# Token do bot criado via @BotFather no Telegram
TELEGRAM_BOT_TOKEN=


# ── AI / LLM ─────────────────────────────────────────────────
# Opção 1: OpenAI API (padrão recomendado para MVP)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Opção 2: LLM local via Ollama (mesma VPS ou servidor dedicado)
# Descomente e configure se preferir não usar OpenAI
# LOCAL_LLM_BASE_URL=http://ollama:11434/v1
# LOCAL_LLM_MODEL=llama3.2


# ── CLÍNICA ──────────────────────────────────────────────────
# Fuso horário (lista: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones)
CLINIC_TIMEZONE=America/Sao_Paulo

# SLA de retorno para novos leads (em horas)
CLINIC_SLA_HOURS=2


# ── WHATSAPP (Phase 2 — deixe comentado no MVP) ──────────────
# Provider: evolution_api (self-hosted) ou outro compatível
# WHATSAPP_PROVIDER=evolution_api
# WHATSAPP_API_URL=https://evolution.seudominio.com
# WHATSAPP_INSTANCE=openclinic
# WHATSAPP_API_KEY=


# ── GOOGLE CALENDAR (Phase 2) ────────────────────────────────
# Credenciais OAuth do Google Cloud Console
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# Chave para criptografar tokens OAuth no banco (openssl rand -hex 32)
# ENCRYPTION_KEY=


# ── TRAEFIK DASHBOARD ────────────────────────────────────────
# Acesso em: https://traefik.seudominio.com
# Gere com: echo $(htpasswd -nb admin SUASENHA) | sed -e s/\\$/\\$\\$/g
# Instalar htpasswd: apt-get install -y apache2-utils
TRAEFIK_DASHBOARD_AUTH=


# ── API KEY PARA WEBHOOKS EXTERNOS ───────────────────────────
# Usado para receber leads de formulários, Google Ads e Meta Ads
# Gere com: openssl rand -hex 24
LEADS_WEBHOOK_API_KEY=


# ── DESENVOLVIMENTO LOCAL (ignorado em produção) ─────────────
# Descomente apenas se estiver desenvolvendo localmente
# ENVIRONMENT=development
